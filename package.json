{
  "name": "originfence",
  "version": "0.1.1-alpha",
  "private": true,
  "description": "Policy-first dependency trust gate for npm and PyPI.",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "clean:bundle": "node -e \"require('node:fs').rmSync('bundle/github-action', { recursive: true, force: true })\"",
    "build": "npm run clean && npm run clean:bundle && tsc -p tsconfig.runtime.json && ncc build dist/src/github-action.js -o bundle/github-action && node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build:test": "npm run clean && tsc -p tsconfig.json",
    "canary:live": "npm run build:test && node scripts/run-live-canaries.js",
    "test": "npm run build:test && node --test dist/tests/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "sigstore": "^4.1.0",
    "toml": "^3.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.9.2"
  }
}
