{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://originfence.local/schemas/cache-record.schema.json",
  "title": "OriginFence Cache Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_identifier",
    "lookup_key",
    "fetched_at",
    "freshness_target",
    "signal_class"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "source_identifier": {
      "type": "string",
      "minLength": 1
    },
    "lookup_key": {
      "type": "string",
      "minLength": 1
    },
    "fetched_at": {
      "type": "string",
      "format": "date-time"
    },
    "freshness_target": {
      "type": "string",
      "minLength": 1
    },
    "etag": {
      "type": "string"
    },
    "last_modified": {
      "type": "string"
    },
    "serial": {
      "type": "string"
    },
    "signal_class": {
      "enum": [
        "hard",
        "soft"
      ]
    }
  }
}
