{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://originfence.local/schemas/waivers.schema.json",
  "title": "OriginFence Waivers",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "waivers"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "owner",
          "justification",
          "created_at",
          "expires_at",
          "scope",
          "reason_codes",
          "effect"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "justification": {
            "type": "string",
            "minLength": 1
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "ecosystem": {
                "enum": [
                  "npm",
                  "pypi"
                ]
              },
              "package": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            }
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "effect": {
            "enum": [
              "downgrade_to_warn",
              "downgrade_to_allow"
            ]
          }
        }
      }
    }
  }
}
